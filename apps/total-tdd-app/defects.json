      "solution_patch": "solutions/D007-import-loan-member-limit.patch"
    },
    {
      "id": "D008",
      "category": "subtle-cross-feature",
      "summary": "Audit logging deduplicates same-day book/member operations, dropping checkout-return interleavings.",
      "files": ["shelfd/audit.py", "shelfd/circulation.py"],
