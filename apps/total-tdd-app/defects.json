  "defects": [
    {
      "id": "D001",
      "category": "straightforward-single-function",
      "summary": "Author search is case-sensitive even though text search and genre filters are normalized.",
      "files": ["shelfd/catalog.py"],
      "match_rules": [
        {"keywords": ["author", "case"]},
        {"keywords": ["search", "le guin"], "files": ["catalog.py"]}
      ],
      "fail_to_pass": ["tests/test_catalog.py::test_author_filter_is_case_insensitive"],
      "solution_patch": "solutions/D001-author-filter-case.patch"
    },
    {
      "id": "D002",
      "category": "straightforward-single-function",
      "summary": "Late fees forgive the first late day, undercharging all overdue returns.",
      "files": ["shelfd/fees.py"],
      "match_rules": [
        {"keywords": ["late", "fee", "day"], "files": ["shelfd/fees.py"]},
        {"keywords": ["75", "50"], "files": ["fees.py"]}
      ],
      "fail_to_pass": ["tests/test_circulation.py::test_late_fee_charges_each_late_day"],
      "solution_patch": "solutions/D002-late-fee-all-days.patch"
    },
    {
      "id": "D003",
      "category": "medium-module-contract",
      "summary": "The API accepts ISO due dates but circulation stores the raw string before comparing it with dates.",
      "files": ["shelfd/api.py", "shelfd/circulation.py", "shelfd/models.py"],
      "match_rules": [
        {"keywords": ["due", "iso", "date"], "files": ["shelfd/circulation.py"]},
        {"keywords": ["api", "checkout", "string"], "files": ["circulation.py"]}
      ],
      "fail_to_pass": ["tests/test_circulation.py::test_checkout_accepts_iso_due_date_through_api"],
      "solution_patch": "solutions/D003-api-due-date-contract.patch"
    },
    {
      "id": "D004",
      "category": "medium-boundary-condition",
      "summary": "Member checkout limits use a greater-than check, allowing one loan beyond the configured limit.",
      "files": ["shelfd/members.py", "shelfd/circulation.py"],
      "match_rules": [
        {"keywords": ["member", "limit", "fourth"], "files": ["shelfd/members.py"]},
        {"keywords": ["max_loans", "boundary"], "files": ["members.py"]}
      ],
      "fail_to_pass": ["tests/test_members.py::test_member_limit_blocks_fourth_checkout"],
      "solution_patch": "solutions/D004-member-limit-boundary.patch"
    },
    {
      "id": "D005",
      "category": "medium-state-leak",
      "summary": "Overdue queries keep a mutable seen-list across calls, so repeated reads lose active loans.",
      "files": ["shelfd/circulation.py"],
      "match_rules": [
        {"keywords": ["overdue", "repeatable", "state"], "files": ["shelfd/circulation.py"]},
        {"keywords": ["mutable", "seen"], "files": ["circulation.py"]}
      ],
      "fail_to_pass": ["tests/test_circulation.py::test_overdue_loans_are_repeatable_queries"],
      "solution_patch": "solutions/D005-overdue-query-state-leak.patch"
    },
    {
      "id": "D006",
      "category": "subtle-cross-feature",
      "summary": "Renewal ignores a waiting reservation, letting a borrower extend a reserved book and avoid late-fee pressure.",
      "files": ["shelfd/circulation.py", "shelfd/fees.py"],
      "match_rules": [
        {"keywords": ["renew", "reservation"], "files": ["shelfd/circulation.py"]},
        {"keywords": ["reserved", "late", "fee"], "files": ["circulation.py"]}
      ],
      "fail_to_pass": ["tests/test_circulation.py::test_reserved_book_cannot_be_renewed_to_avoid_late_fee"],
      "solution_patch": "solutions/D006-reservation-renewal.patch"
    },
    {
      "id": "D007",
      "category": "subtle-cross-feature",
      "summary": "Loan CSV import creates active loans directly and bypasses the member-limit invariant used by checkout.",
      "files": ["shelfd/io.py", "shelfd/members.py", "shelfd/circulation.py"],
      "match_rules": [
        {"keywords": ["import", "loan", "limit"], "files": ["shelfd/io.py"]},
